{
  "name": "vscode-mdf",
  "displayName": "mdf-vscode",
  "description": "Live preview, syntax highlighting and snippets for mdf Markdown",
  "version": "0.1.1",
  "publisher": "kobekeye",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kobekeye/mdf"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Formatters"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./out/extension.js",
  "configurationDefaults": {
    "[markdown]": {
      "editor.quickSuggestions": {
        "other": "inline",
        "comments": "off",
        "strings": "off"
      },
      "editor.snippetSuggestions": "top"
    }
  },
  "contributes": {
    "grammars": [
      {
        "scopeName": "mdf.injection.markdown",
        "path": "./syntaxes/mdf-markdown.injection.tmLanguage.json",
        "injectTo": [
          "text.html.markdown"
        ]
      }
    ],
    "snippets": [
      {
        "language": "markdown",
        "path": "./snippets/mdf-snippets.json"
      }
    ],
    "commands": [
      {
        "command": "mdf.openPreview",
        "title": "MDF: Open Preview",
        "icon": "$(open-preview)"
      },
      {
        "command": "mdf.exportPdf",
        "title": "MDF: Export PDF",
        "icon": "$(export)"
      },
      {
        "command": "mdf.switchMode",
        "title": "MDF: Switch Mode"
      },
      {
        "command": "mdf.showOutput",
        "title": "MDF: Show Output"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "mdf.openPreview",
          "when": "resourceLangId == markdown",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "mdf",
      "properties": {
        "mdf.mode": {
          "type": "string",
          "enum": [
            "html",
            "typst"
          ],
          "enumDescriptions": [
            "HTML pipeline: Markdown → HTML preview (KaTeX math)",
            "Typst pipeline: Markdown → Typst → SVG preview (fast, incremental)"
          ],
          "default": "html",
          "description": "mdf 模式：影響 math snippets、preview 行為和 PDF 輸出 pipeline"
        },
        "mdf.theme": {
          "type": "string",
          "enum": [
            "default",
            "asterisk"
          ],
          "enumDescriptions": [
            "Default — Inter + Noto Sans TC, clean and modern",
            "Asterisk — Tinos + Noto Serif TC, warm and refined"
          ],
          "default": "default",
          "description": "Preview 與 PDF 輸出使用的主題"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run typecheck && node build.js",
    "compile": "npm run typecheck && node build.js",
    "watch": "node build.js --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "npm run compile && node test/preview-smoke.js && node test/webview-smoke.js",
    "test:webview": "node test/webview-smoke.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.25.0",
    "jsdom": "^29.0.2",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@myriaddreamin/typst-ts-renderer": "^0.7.0-rc2",
    "@myriaddreamin/typst-ts-web-compiler": "^0.7.0-rc2",
    "@myriaddreamin/typst.ts": "^0.7.0-rc2"
  }
}
