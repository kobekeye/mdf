{
  "name": "@kobekeye/mdf",
  "version": "1.2.0",
  "description": "Convert Markdown to beautiful PDFs — free, open-source, and zero-config.",
  "main": "src/cli.js",
  "bin": {
    "mdf": "src/cli.js"
  },
  "files": [
    "src/",
    "themes/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node test/run.js",
    "test:playground-fonts": "npm run playground:build && node test/playground-typst-fonts.js",
    "playground:dev": "vite --config playground/vite.config.ts",
    "playground:build": "vite build --config playground/vite.config.ts"
  },
  "keywords": [
    "markdown",
    "pdf",
    "converter",
    "cli",
    "katex",
    "syntax-highlighting"
  ],
  "author": "kobekeye",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "type": "commonjs",
  "devDependencies": {
    "@myriaddreamin/typst-ts-node-compiler": "0.7.0-rc2",
    "@myriaddreamin/typst-ts-renderer": "0.7.0-rc2",
    "@myriaddreamin/typst-ts-web-compiler": "0.7.0-rc2",
    "@myriaddreamin/typst.ts": "0.7.0-rc2",
    "typescript": "^5.9.3",
    "vite": "^7.3.3"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.33",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-container": "^4.0.0",
    "markdown-it-github-alerts": "^1.0.1",
    "markdown-it-task-lists": "^2.1.1",
    "markdown-it-texmath": "^1.0.0",
    "puppeteer-core": "^24.40.0"
  }
}
